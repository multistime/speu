# Optional: canonical site URLs for the project hub (/admin/project)
# NEXT_PUBLIC_SPEU_PRODUCTION_URL=https://speu.vercel.app
# NEXT_PUBLIC_SPEU_STAGING_URL=https://your-staging-url.vercel.app
# NEXT_PUBLIC_SITE_URL=https://speu.vercel.app

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only: admin API DB/storage after is_admin check (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: `supabase/db-push.sh` / `npx supabase db push` (без `supabase login`)
# Пароль з Dashboard → Settings → Database (не публікуй у git)
# SUPABASE_DB_PASSWORD=your_database_password
# Калі паддамен у URL не супадае з Project ref (Settings → General):
# SPEU_SUPABASE_PROJECT_REF=your_20_char_project_ref

# Optional: LLM provider for production lyrics generation
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
